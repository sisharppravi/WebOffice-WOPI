@page "/editor"
@layout EditorLayout
@inject HttpClient HttpClient
@inject IJSRuntime JS

<PageTitle>OnlyOffice Editor</PageTitle>

<div class="editor-page">
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger m-3">@_errorMessage</div>
    }
    else if (_loading)
    {
        <p class="m-3">Загрузка редактора...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_launchUrl))
    {
        <p class="m-3">Открываем редактор...</p>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    public string? UserId { get; set; }

    [SupplyParameterFromQuery]
    public string? FileName { get; set; }

    private bool _loading = true;
    private string? _errorMessage;
    private string? _launchUrl;
    private string? _accessToken;
    private long _accessTokenTtl;
    private bool _submitted;

    private sealed class WopiLaunchResponse
    {
        public string? LaunchUrl { get; set; }
        public string? AccessToken { get; set; }
        public long AccessTokenTtl { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(FileName))
            {
                throw new InvalidOperationException("Не переданы параметры userId или fileName.");
            }

            var url = $"wopi/editor-launch?userId={Uri.EscapeDataString(UserId)}&fileName={Uri.EscapeDataString(FileName)}";
            var launch = await HttpClient.GetFromJsonAsync<WopiLaunchResponse>(url);
            if (string.IsNullOrWhiteSpace(launch?.LaunchUrl))
            {
                throw new InvalidOperationException("Не удалось получить WOPI launch URL.");
            }

            _launchUrl = launch.LaunchUrl;
            _accessToken = launch.AccessToken;
            _accessTokenTtl = launch.AccessTokenTtl;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Ошибка запуска редактора: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_submitted || string.IsNullOrWhiteSpace(_launchUrl) || string.IsNullOrWhiteSpace(_accessToken))
        {
            return;
        }

        _submitted = true;
        await JS.InvokeVoidAsync("submitWopiPost", _launchUrl, _accessToken, _accessTokenTtl);
    }

}



